<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkBox" id="status_bar_root">
    <property name="orientation">horizontal</property>
    <property name="spacing">0</property>
    <style>
      <class name="status-bar"/>
    </style>
    <child>
      <object class="GtkBox" id="status_left_box">
        <property name="orientation">horizontal</property>
        <property name="spacing">16</property>
        <style>
          <class name="status-left"/>
        </style>
        <child>
          <object class="GtkLabel" id="status_doc_label">
            <property name="label"></property>
            <style>
              <class name="status-label"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="status_cursor_label">
            <property name="label">Tool: Brush (B)</property>
            <style>
              <class name="status-label"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="status_center_box">
        <property name="orientation">horizontal</property>
        <property name="spacing">12</property>
        <style>
          <class name="status-center"/>
        </style>
        <child>
          <object class="GtkLabel" id="status_notice_label">
            <property name="label">Ready</property>
            <property name="hexpand">True</property>
            <property name="xalign">0.5</property>
            <style>
              <class name="status-notice"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="status_right_box">
        <property name="orientation">horizontal</property>
        <property name="spacing">16</property>
        <property name="hexpand">True</property>
        <property name="halign">end</property>
        <style>
          <class name="status-right"/>
        </style>
        <child>
          <object class="GtkLabel" id="status_zoom_label">
            <property name="label">Zoom: 100%</property>
            <style>
              <class name="status-label"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="status_mode_label">
            <property name="label">RGB/8</property>
            <style>
              <class name="status-label"/>
            </style>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
