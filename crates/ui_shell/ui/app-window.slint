                            clicked => { root.tool-triggered("Shape"); }
                        }

                        ToolRailDivider { border-subtle: root.border-subtle; }

                        ToolRailButton {
                            bg-default: root.bg-chrome;
                            button-bg-hover: root.button-bg-hover;
                            button-bg-active: root.button-bg-active;
                            border-subtle: root.border-subtle;
                            accent-primary: root.accent-primary;
                            text-primary: root.text-primary;
                            text-secondary: root.text-secondary;
                            icon: @image-url("../../../assets/icons/RemixIcons/Editor/cursor-hand.svg");
                            text: "Hand";
                            active: root.active-tool-key == "Hand";
                            clicked => { root.tool-triggered("Hand"); }
                        }

                        ToolRailButton {
                            bg-default: root.bg-chrome;
                            button-bg-hover: root.button-bg-hover;
                            button-bg-active: root.button-bg-active;
                            border-subtle: root.border-subtle;
                            accent-primary: root.accent-primary;
                            text-primary: root.text-primary;
                            text-secondary: root.text-secondary;
                            icon: @image-url("../../../assets/icons/RemixIcons/System/zoom-in-line.svg");
                            text: "Zoom";
                            active: root.active-tool-key == "Zoom";
                            clicked => { root.tool-triggered("Zoom"); }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            min-height: 124px;
                            background: root.bg-panel;
                            border-color: root.border-default;
                            border-width: 1px;
                            border-radius: 4px;

                            VerticalLayout {
                                padding-top: 6px;
                                padding-left: 4px;
                                padding-right: 4px;
                                padding-bottom: 6px;
                                spacing: 4px;

                                Rectangle {
                                    min-height: 36px;

                                    HorizontalLayout {
                                        spacing: 2px;

                                        Rectangle {
                                            width: 14px;
                                            height: 14px;
                                            border-radius: 2px;
                                            background: root.accent-primary;
                                            border-color: root.border-strong;
                                            border-width: 1px;
                                        }

                                        Rectangle {
                                            width: 14px;
                                            height: 14px;
                                            border-radius: 2px;
                                            background: #101216;
                                            border-color: root.border-strong;
                                            border-width: 1px;
                                            y: 14px;
                                        }
                                    }
                                }

                                IconButton {
                                    bg-default: root.bg-panel;
                                    button-bg-hover: root.button-bg-hover;
                                    button-bg-active: root.button-bg-active;
                                    border-default: root.border-default;
                                    accent-primary: root.accent-primary;
                                    text-primary: root.text-primary;
                                    text-secondary: root.text-secondary;
                                    icon: @image-url("../../../assets/icons/RemixIcons/Finance/swap-line.svg");
                                    clicked => { root.command-triggered("Swap Colors"); }
                                }

                                IconButton {
                                    bg-default: root.bg-panel;
                                    button-bg-hover: root.button-bg-hover;
                                    button-bg-active: root.button-bg-active;
                                    border-default: root.border-default;
                                    accent-primary: root.accent-primary;
                                    text-primary: root.text-primary;
                                    text-secondary: root.text-secondary;
                                    icon: @image-url("../../../assets/icons/RemixIcons/System/refresh-line.svg");
                                    clicked => { root.command-triggered("Reset Colors"); }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    background: root.bg-app;

                    VerticalLayout {
                        spacing: 0px;

                        Rectangle {
                            height: root.tab-height;
                            background: root.bg-chrome;
                            border-color: root.border-subtle;
                            border-width: 1px;

                            HorizontalLayout {
                                padding-left: root.panel-padding;
                                padding-right: root.panel-padding;
                                spacing: 8px;

                                Rectangle {
                                    min-width: 316px;
                                    background: root.bg-panel;
                                    border-color: root.document-dirty ? root.accent-primary : root.border-default;
                                    border-width: 1px;
                                    border-radius: 4px;

                                    Rectangle {
                                        x: 0px;
                                        y: 0px;
                                        width: parent.width;
                                        height: 2px;
                                        background: root.document-dirty ? root.accent-primary : root.border-strong;
                                    }

                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 6px;
                                        spacing: 8px;

                                        Image {
                                            source: @image-url("../../../assets/icons/RemixIcons/Design/layout-grid-line.svg");
                                            width: 12px;
                                            height: 12px;
                                            colorize: root.text-secondary;
                                            y: (parent.height - self.height) / 2;
                                        }

                                        VerticalLayout {
                                            spacing: 0px;

                                            Text {
                                                text: root.document-title;
                                                color: root.text-primary;
                                                font-size: 11px;
                                                font-weight: 600;
                                            }

                                            Text {
                                                text: root.zoom-label + "  •  RGB/8";
                                                color: root.text-muted;
                                                font-size: 9px;
                                            }
                                        }

                                        if root.document-dirty : Rectangle {
                                            width: 7px;
                                            height: 7px;
                                            border-radius: 4px;
                                            background: root.accent-primary;
                                            y: (parent.height - self.height) / 2;
                                        }

                                        Rectangle {}

                                        IconButton {
                                            bg-default: #00000000;
                                            button-bg-hover: root.button-bg-hover;
                                            button-bg-active: root.button-bg-active;
                                            border-default: #00000000;
                                            accent-primary: root.accent-primary;
                                            text-primary: root.text-primary;
                                            text-secondary: root.text-secondary;
                                            icon: @image-url("../../../assets/icons/RemixIcons/System/close-line.svg");
                                            clicked => { root.command-triggered("Close Document"); }
                                        }
                                    }
                                }

                                IconButton {
                                    bg-default: root.bg-panel;
                                    button-bg-hover: root.button-bg-hover;
                                    button-bg-active: root.button-bg-active;
                                    border-default: root.border-default;
                                    accent-primary: root.accent-primary;
                                    text-primary: root.text-primary;
                                    text-secondary: root.text-secondary;
                                    icon: @image-url("../../../assets/icons/RemixIcons/System/add-line.svg");
                                    clicked => { root.command-triggered("New Document"); }
                                }

                                Rectangle {}
                            }
                        }

                        Rectangle {
                            background: root.bg-canvas-surround;
                            border-color: root.border-subtle;
                            border-width: 1px;

                            Rectangle {
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                width: parent.width * 0.9;
                                height: parent.height * 0.86;
                                background: #101216;
                                border-color: root.border-strong;
                                border-width: 1px;
                                border-radius: 8px;

                                Rectangle {
                                    x: 22px;
                                    y: 6px;
                                    width: parent.width - 44px;
                                    height: 14px;
                                    background: root.bg-panel-header;
                                    border-color: root.border-default;
                                    border-width: 1px;
                                    border-radius: 3px;

                                    for tick[index] in [0, 1, 2, 3, 4, 5, 6, 7] : Rectangle {
                                        x: 12px + index * ((parent.width - 24px) / 8);
                                        y: Math.mod(index, 2) == 0 ? 5px : 8px;
                                        width: 1px;
                                        height: Math.mod(index, 2) == 0 ? 6px : 3px;
                                        background: root.text-muted;
                                    }
                                }

                                Rectangle {
                                    x: 6px;
                                    y: 22px;
                                    width: 14px;
                                    height: parent.height - 44px;
                                    background: root.bg-panel-header;
                                    border-color: root.border-default;
                                    border-width: 1px;
                                    border-radius: 3px;

                                    for tick[index] in [0, 1, 2, 3, 4, 5, 6, 7] : Rectangle {
                                        x: Math.mod(index, 2) == 0 ? 5px : 8px;
                                        y: 12px + index * ((parent.height - 24px) / 8);
                                        width: Math.mod(index, 2) == 0 ? 6px : 3px;
                                        height: 1px;
                                        background: root.text-muted;
                                    }
                                }

                                Rectangle {
                                    x: 22px;
                                    y: 22px;
                                    width: parent.width - 44px;
                                    height: parent.height - 44px;
                                    background: #50555F;
                                    border-color: root.border-strong;
                                    border-width: 1px;

                                    Rectangle {
                                        x: 2px;
                                        y: 2px;
                                        width: parent.width - 4px;
                                        height: parent.height - 4px;
                                        background: #3E434C;
                                        opacity: 0.42;
                                    }

                                    Image {
                                        x: 2px;
                                        y: 2px;
                                        width: parent.width - 4px;
                                        height: parent.height - 4px;
                                        source: root.canvas-preview;
                                        image-fit: contain;
                                    }

                                    TouchArea {
                                        width: 100%;
                                        height: 100%;
                                        mouse-cursor: root.active-tool-key == "Hand" ? grab : root.active-tool-key == "Move" ? move : crosshair;

                                        pointer-event(event) => {
                                            let normalized-x = self.mouse-x / self.width;
                                            let normalized-y = self.mouse-y / self.height;

                                            if event.kind == PointerEventKind.down {
                                                root.active-menu-index = -1;
                                                root.canvas-pressed(normalized-x, normalized-y);
                                            }

                                            if event.kind == PointerEventKind.up {
                                                root.canvas-released(normalized-x, normalized-y);
                                            }
                                        }

                                        moved => {
                                            let normalized-x = self.mouse-x / self.width;
                                            let normalized-y = self.mouse-y / self.height;

                                            if self.pressed {
                                                root.canvas-dragged(normalized-x, normalized-y);
                                            } else {
                                                root.canvas-hovered(normalized-x, normalized-y);
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    x: 14px;
                                    y: 28px;
                                    width: 160px;
                                    height: 22px;
                                    border-radius: 4px;
                                    background: root.bg-panel;
                                    border-color: root.border-default;
                                    border-width: 1px;

                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 6px;

                                        Image {
                                            source: @image-url("../../../assets/icons/RemixIcons/System/search-eye-line.svg");
                                            width: 14px;
                                            height: 14px;
                                            colorize: root.text-secondary;
                                            y: (parent.height - self.height) / 2;
                                        }

                                        Text {
                                            text: root.zoom-label + "  •  " + root.canvas-size-label;
                                            color: root.text-secondary;
                                            font-size: 9px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                Rectangle {
                                    x: (parent.width - self.width) / 2;
                                    y: parent.height - self.height - 10px;
                                    width: 254px;
                                    height: 26px;
                                    border-radius: 8px;
                                    background: root.bg-panel;
                                    border-color: root.border-default;
                                    border-width: 1px;

                                    HorizontalLayout {
                                        padding-left: 10px;
                                        padding-right: 10px;
                                        spacing: 10px;

                                        Text {
                                            text: root.active-tool-label;
                                            color: root.text-primary;
                                            font-size: 10px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                        }

                                        Rectangle {
                                            width: 1px;
                                            background: root.border-subtle;
                                        }

                                        Text {
                                            text: "Space Pan";
                                            color: root.text-secondary;
                                            font-size: 10px;
                                            vertical-alignment: center;
                                        }

                                        Text {
                                            text: "Ctrl+S Save";
                                            color: root.text-secondary;
                                            font-size: 10px;
                                            vertical-alignment: center;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    width: root.right-dock-width;
                    background: root.bg-panel;
                    border-color: root.border-subtle;
                    border-width: 1px;

                    HorizontalLayout {
                        spacing: 0px;

                        Rectangle {
                            width: 28px;
                            background: root.bg-panel-header;
                            border-color: root.border-subtle;
                            border-width: 1px;

                            VerticalLayout {
                                padding-top: 6px;
                                padding-left: 3px;
                                padding-right: 3px;
                                spacing: 4px;

                                IconButton {
                                    bg-default: root.bg-panel-header;
                                    button-bg-hover: root.button-bg-hover;
                                    button-bg-active: root.button-bg-active;
                                    border-default: root.border-default;
                                    accent-primary: root.accent-primary;
                                    text-primary: root.text-primary;
                                    text-secondary: root.text-secondary;
                                    icon: @image-url("../../../assets/icons/RemixIcons/Design/palette-line.svg");
                                    active: root.dock-shortcut-index == 0;
                                    clicked => { root.dock-shortcut-index = 0; root.top-panel-index = 0; }
                                }

                                IconButton {
                                    bg-default: root.bg-panel-header;
                                    button-bg-hover: root.button-bg-hover;
                                    button-bg-active: root.button-bg-active;
                                    border-default: root.border-default;
                                    accent-primary: root.accent-primary;
                                    text-primary: root.text-primary;
                                    text-secondary: root.text-secondary;
                                    icon: @image-url("../../../assets/icons/RemixIcons/System/history-line.svg");
                                    active: root.dock-shortcut-index == 1;
                                    clicked => { root.dock-shortcut-index = 1; root.middle-panel-index = 2; }
                                }

                                IconButton {
                                    bg-default: root.bg-panel-header;
                                    button-bg-hover: root.button-bg-hover;
                                    button-bg-active: root.button-bg-active;
                                    border-default: root.border-default;
                                    accent-primary: root.accent-primary;
                                    text-primary: root.text-primary;
                                    text-secondary: root.text-secondary;
                                    icon: @image-url("../../../assets/icons/RemixIcons/System/settings-3-line.svg");
                                    active: root.dock-shortcut-index == 2;
                                    clicked => { root.dock-shortcut-index = 2; root.middle-panel-index = 1; }
                                }

                                IconButton {
                                    bg-default: root.bg-panel-header;
                                    button-bg-hover: root.button-bg-hover;
                                    button-bg-active: root.button-bg-active;
                                    border-default: root.border-default;
                                    accent-primary: root.accent-primary;
                                    text-primary: root.text-primary;
                                    text-secondary: root.text-secondary;
                                    icon: @image-url("../../../assets/icons/RemixIcons/Business/stack-line.svg");
                                    active: root.dock-shortcut-index == 3;
                                    clicked => { root.dock-shortcut-index = 3; root.bottom-panel-index = 0; }
                                }

                                Rectangle {}
                            }
                        }

                        Rectangle {
                            background: root.bg-panel;
                            border-color: root.border-subtle;
                            border-width: 1px;
                            horizontal-stretch: 1;

                            VerticalLayout {
                                spacing: 4px;
                                padding-top: 3px;
                                padding-left: 4px;
                                padding-right: 4px;
                                padding-bottom: 3px;

                                Rectangle {
                                    min-height: 164px;
                                    background: root.bg-panel;
                                    border-color: root.border-default;
                                    border-width: 1px;

                                    VerticalLayout {
                                        spacing: 0px;

                                        Rectangle {
                                            height: root.panel-header-height;
                                            background: root.bg-panel-header;

                                            HorizontalLayout {
                                                padding-left: 4px;
                                                padding-right: 4px;
                                                spacing: 2px;

                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "Color"; active: root.top-panel-index == 0; clicked => { root.top-panel-index = 0; root.dock-shortcut-index = 0; } }
                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "Swatches"; active: root.top-panel-index == 1; clicked => { root.top-panel-index = 1; root.dock-shortcut-index = 0; } }
                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "Gradients"; active: root.top-panel-index == 2; clicked => { root.top-panel-index = 2; root.dock-shortcut-index = 0; } }
                                                Rectangle {}
                                            }
                                        }

                                        Rectangle {
                                            background: root.bg-panel;
                                            vertical-stretch: 1;

                                            if root.top-panel-index == 0 : HorizontalLayout {
                                                padding-left: 6px;
                                                padding-right: 6px;
                                                padding-top: 6px;
                                                padding-bottom: 6px;
                                                spacing: 6px;

                                                Rectangle {
                                                    background: root.bg-panel-header;
                                                    border-color: root.border-default;
                                                    border-width: 1px;
                                                    border-radius: 3px;
                                                    horizontal-stretch: 1;

                                                    Rectangle {
                                                        x: 8px;
                                                        y: 8px;
                                                        width: parent.width - 16px;
                                                        height: parent.height - 16px;
                                                        border-radius: 2px;
                                                        background: root.accent-primary;

                                                        Rectangle {
                                                            x: parent.width * 0.55;
                                                            y: 0px;
                                                            width: parent.width * 0.45;
                                                            height: parent.height;
                                                            background: #ffffff26;
                                                        }

                                                        Rectangle {
                                                            x: 0px;
                                                            y: parent.height * 0.58;
                                                            width: parent.width;
                                                            height: parent.height * 0.42;
                                                            background: #00000038;
                                                        }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 14px;
                                                    background: #00000000;

                                                    Rectangle { x: 0px; y: 0px; width: parent.width; height: parent.height; border-radius: 2px; background: #ff2a2a; }
                                                    Rectangle { x: 0px; y: parent.height * 0.18; width: parent.width; height: parent.height * 0.18; background: #ff8c00; }
                                                    Rectangle { x: 0px; y: parent.height * 0.36; width: parent.width; height: parent.height * 0.18; background: #f7e95b; }
                                                    Rectangle { x: 0px; y: parent.height * 0.54; width: parent.width; height: parent.height * 0.18; background: #42d96b; }
                                                    Rectangle { x: 0px; y: parent.height * 0.72; width: parent.width; height: parent.height * 0.14; background: #2e85ff; }
                                                    Rectangle { x: 0px; y: parent.height * 0.86; width: parent.width; height: parent.height * 0.14; background: #d546ff; }
                                                }
                                            }

                                            if root.top-panel-index == 1 : VerticalLayout {
                                                padding-top: 8px;
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                padding-bottom: 8px;
                                                spacing: 6px;

                                                for swatch in [#f55b5b, #f39c12, #f4d35e, #5bd66c, #4f8cff, #8b5cf6, #ec4899, #e8ecf3] : Rectangle {
                                                    height: 18px;
                                                    border-radius: 3px;
                                                    background: swatch;
                                                    border-color: root.border-default;
                                                    border-width: 1px;
                                                }
                                            }

                                            if root.top-panel-index == 2 : VerticalLayout {
                                                padding-top: 8px;
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                padding-bottom: 8px;
                                                spacing: 6px;

                                                Rectangle { height: 22px; border-radius: 3px; background: @linear-gradient(90deg, #4f8cff, #8b5cf6); border-color: root.border-default; border-width: 1px; }
                                                Rectangle { height: 22px; border-radius: 3px; background: @linear-gradient(90deg, #ff914d, #ffe066); border-color: root.border-default; border-width: 1px; }
                                                Rectangle { height: 22px; border-radius: 3px; background: @linear-gradient(90deg, #14161A, #E8ECF3); border-color: root.border-default; border-width: 1px; }
                                                Rectangle {}
                                            }
                                        }

                                        if root.top-panel-index == 0 : HorizontalLayout {
                                            padding-left: 6px;
                                            padding-right: 6px;
                                            padding-bottom: 6px;
                                            spacing: 6px;

                                            Rectangle {
                                                min-height: 30px;
                                                background: root.bg-panel-header;
                                                border-color: root.border-default;
                                                border-width: 1px;
                                                border-radius: 3px;
                                                horizontal-stretch: 1;

                                                VerticalLayout {
                                                    padding-top: 4px;
                                                    padding-left: 6px;
                                                    spacing: 1px;
                                                    Text { text: "Foreground"; color: root.text-muted; font-size: 9px; font-weight: 600; }
                                                    Text { text: root.foreground-color-label; color: root.text-primary; font-size: 10px; font-weight: 600; }
                                                }
                                            }

                                            Rectangle {
                                                min-height: 30px;
                                                background: root.bg-panel-header;
                                                border-color: root.border-default;
                                                border-width: 1px;
                                                border-radius: 3px;
                                                horizontal-stretch: 1;

                                                VerticalLayout {
                                                    padding-top: 4px;
                                                    padding-left: 6px;
                                                    spacing: 1px;
                                                    Text { text: "Background"; color: root.text-muted; font-size: 9px; font-weight: 600; }
                                                    Text { text: root.background-color-label; color: root.text-primary; font-size: 10px; font-weight: 600; }
                                                }
                                            }
                                        }

                                        if root.top-panel-index != 0 : Rectangle {
                                            height: 8px;
                                            background: #00000000;
                                        }
                                    }
                                }

                                Rectangle {
                                    min-height: 96px;
                                    background: root.bg-panel;
                                    border-color: root.border-default;
                                    border-width: 1px;

                                    VerticalLayout {
                                        spacing: 0px;

                                        Rectangle {
                                            height: root.panel-header-height;
                                            background: root.bg-panel-header;

                                            HorizontalLayout {
                                                padding-left: 4px;
                                                padding-right: 4px;
                                                spacing: 2px;

                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "Libraries"; active: root.middle-panel-index == 0; clicked => { root.middle-panel-index = 0; root.dock-shortcut-index = 2; } }
                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "Adjustments"; active: root.middle-panel-index == 1; clicked => { root.middle-panel-index = 1; root.dock-shortcut-index = 2; } }
                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "History"; active: root.middle-panel-index == 2; clicked => { root.middle-panel-index = 2; root.dock-shortcut-index = 1; } }
                                                Rectangle {}
                                            }
                                        }

                                        Rectangle {
                                            background: root.bg-panel;
                                            vertical-stretch: 1;

                                            if root.middle-panel-index == 0 : VerticalLayout {
                                                padding-top: 6px;
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                spacing: 4px;

                                                Text { text: "Workspace assets"; color: root.text-primary; font-size: 10px; font-weight: 600; }
                                                Text { text: "Library linking is later scope, but this region now behaves like a real panel tab."; color: root.text-muted; font-size: 9px; wrap: word-wrap; }
                                                Rectangle {}
                                            }

                                            if root.middle-panel-index == 1 : VerticalLayout {
                                                padding-top: 6px;
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                spacing: 4px;

                                                Text { text: "Adjustments"; color: root.text-primary; font-size: 10px; font-weight: 600; }
                                                for adj in ["Brightness", "Levels", "Curves", "Hue/Sat"] : Rectangle {
                                                    height: 18px;
                                                    border-radius: 3px;
                                                    background: root.bg-panel-header;
                                                    border-color: root.border-default;
                                                    border-width: 1px;
                                                    Text { text: adj; color: root.text-secondary; font-size: 9px; vertical-alignment: center; x: 6px; }
                                                }
                                            }

                                            if root.middle-panel-index == 2 : VerticalLayout {
                                                padding-top: 6px;
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                spacing: 4px;

                                                Text {
                                                    text: root.history-entry-primary;
                                                    color: root.text-primary;
                                                    font-size: 10px;
                                                    font-weight: 600;
                                                }

                                                Text {
                                                    text: root.history-entry-secondary;
                                                    color: root.text-muted;
                                                    font-size: 9px;
                                                }

                                                Text { text: root.history-entry-tertiary; color: root.text-muted; font-size: 9px; }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    background: root.bg-panel;
                                    border-color: root.border-default;
                                    border-width: 1px;
                                    vertical-stretch: 1;

                                    VerticalLayout {
                                        spacing: 0px;

                                        Rectangle {
                                            height: root.panel-header-height;
                                            background: root.bg-panel-header;

                                            HorizontalLayout {
                                                padding-left: 4px;
                                                padding-right: 4px;
                                                spacing: 2px;

                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "Layers"; active: root.bottom-panel-index == 0; clicked => { root.bottom-panel-index = 0; root.dock-shortcut-index = 3; } }
                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "Channels"; active: root.bottom-panel-index == 1; clicked => { root.bottom-panel-index = 1; root.dock-shortcut-index = 3; } }
                                                PanelTab { button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; text-primary: root.text-primary; text-secondary: root.text-secondary; text: "Paths"; active: root.bottom-panel-index == 2; clicked => { root.bottom-panel-index = 2; root.dock-shortcut-index = 3; } }
                                                Rectangle {}
                                                Text {
                                                    text: root.layer-count-label;
                                                    color: root.text-muted;
                                                    font-size: 9px;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }

                                        if root.bottom-panel-index == 0 : Rectangle {
                                            min-height: 24px;
                                            background: root.bg-panel;

                                            HorizontalLayout {
                                                padding-left: 6px;
                                                padding-right: 6px;
                                                spacing: 4px;

                                                CompactOptionChip {
                                                    bg-panel: root.bg-panel-header;
                                                    button-bg-hover: root.button-bg-hover;
                                                    button-bg-active: root.button-bg-active;
                                                    border-default: root.border-default;
                                                    text-primary: root.text-primary;
                                                    text-secondary: root.text-secondary;
                                                    icon: @image-url("../../../assets/icons/RemixIcons/System/search-line.svg");
                                                    label: "Kind";
                                                    value: "All";
                                                }

                                                Rectangle {}

                                                IconButton {
                                                    bg-default: root.bg-panel-header;
                                                    button-bg-hover: root.button-bg-hover;
                                                    button-bg-active: root.button-bg-active;
                                                    border-default: root.border-default;
                                                    accent-primary: root.accent-primary;
                                                    text-primary: root.text-primary;
                                                    text-secondary: root.text-secondary;
                                                    icon: @image-url("../../../assets/icons/RemixIcons/System/search-line.svg");
                                                }
                                            }
                                        }

                                        if root.bottom-panel-index == 0 : Rectangle {
                                            min-height: 24px;
                                            background: root.bg-panel;

                                            HorizontalLayout {
                                                padding-left: 6px;
                                                padding-right: 6px;
                                                spacing: 4px;

                                                CompactOptionChip {
                                                    bg-panel: root.bg-panel-header;
                                                    button-bg-hover: root.button-bg-hover;
                                                    button-bg-active: root.button-bg-active;
                                                    border-default: root.border-default;
                                                    text-primary: root.text-primary;
                                                    text-secondary: root.text-secondary;
                                                    icon: @image-url("../../../assets/icons/RemixIcons/Arrows/arrow-drop-down-line.svg");
                                                    label: "Mode";
                                                    value: root.layer-blend-mode-label;
                                                }

                                                CompactOptionChip {
                                                    bg-panel: root.bg-panel-header;
                                                    button-bg-hover: root.button-bg-hover;
                                                    button-bg-active: root.button-bg-active;
                                                    border-default: root.border-default;
                                                    text-primary: root.text-primary;
                                                    text-secondary: root.text-secondary;
                                                    icon: @image-url("../../../assets/icons/RemixIcons/Arrows/arrow-drop-down-line.svg");
                                                    label: "Opacity";
                                                    value: root.layer-opacity-label;
                                                }
                                            }
                                        }

                                        if root.bottom-panel-index == 0 : Rectangle {
                                            min-height: 24px;
                                            background: root.bg-panel;

                                            HorizontalLayout {
                                                padding-left: 6px;
                                                padding-right: 6px;
                                                spacing: 4px;

                                                Text { text: "Lock:"; color: root.text-muted; font-size: 9px; vertical-alignment: center; }
                                                IconButton { bg-default: root.bg-panel-header; button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; accent-primary: root.accent-primary; text-primary: root.text-primary; text-secondary: root.text-secondary; icon: @image-url("../../../assets/icons/RemixIcons/System/lock-line.svg"); }
                                                IconButton { bg-default: root.bg-panel-header; button-bg-hover: root.button-bg-hover; button-bg-active: root.button-bg-active; border-default: root.border-default; accent-primary: root.accent-primary; text-primary: root.text-primary; text-secondary: root.text-secondary; icon: @image-url("../../../assets/icons/RemixIcons/System/eye-line.svg"); active: true; }
                                                Rectangle {}
                                                Text { text: root.layer-visibility-label; color: root.text-muted; font-size: 9px; vertical-alignment: center; }
                                            }
                                        }

                                        if root.bottom-panel-index == 0 : Rectangle {
                                            background: root.bg-panel;
                                            vertical-stretch: 1;

                                            VerticalLayout {
                                                padding-top: 6px;
                                                padding-left: 6px;
                                                padding-right: 6px;
                                                spacing: 4px;

                                                Rectangle {
                                                    min-height: 36px;
                                                    background: root.bg-panel-header;
                                                    border-color: root.accent-primary;
                                                    border-width: 1px;
                                                    border-radius: 3px;

                                                    HorizontalLayout {
                                                        padding-left: 6px;
                                                        padding-right: 6px;
                                                        spacing: 6px;

                                                        Rectangle {
                                                            width: 18px;
                                                            height: 18px;
                                                            border-radius: 2px;
                                                            background: root.accent-primary;
                                                            border-color: root.border-default;
                                                            border-width: 1px;
                                                            y: (parent.height - self.height) / 2;
                                                        }

                                                        VerticalLayout {
                                                            spacing: 0px;

                                                            Text { text: root.active-layer-name; color: root.text-primary; font-size: 10px; font-weight: 600; }
                                                            Text { text: root.layer-blend-mode-label + "  •  " + root.layer-opacity-label; color: root.text-muted; font-size: 9px; }
                                                        }

                                                        Rectangle {}

                                                        Text { text: root.layer-visibility-label; color: root.text-secondary; font-size: 9px; vertical-alignment: center; }
                                                    }
                                                }

                                                Rectangle {
                                                    min-height: 44px;
                                                    background: root.bg-panel-header;
                                                    border-color: root.border-default;
                                                    border-width: 1px;
                                                    border-radius: 3px;

                                                    VerticalLayout {
                                                        padding-top: 6px;
                                                        padding-left: 6px;
                                                        padding-right: 6px;
                                                        spacing: 2px;
                                                        Text { text: "Canvas"; color: root.text-muted; font-size: 9px; font-weight: 600; }
                                                        Text { text: root.canvas-size-label + "  •  " + root.selection-bounds-label; color: root.text-secondary; font-size: 9px; }
                                                        Text { text: "The fixed dock now follows a grouped panel workspace instead of separate summary cards."; color: root.text-muted; font-size: 9px; wrap: word-wrap; }
                                                    }
                                                }
                                            }
                                        }

                                        if root.bottom-panel-index == 0 : Rectangle {
                                            height: 28px;
                                            background: root.bg-panel-header;
                                            border-color: root.border-default;
                                            border-width: 1px;

                                            HorizontalLayout {
                                                padding-left: 4px;
                                                padding-right: 4px;
                                                spacing: 4px;

                                                IconButton {
                                                    bg-default: root.bg-panel-header;
                                                    button-bg-hover: root.button-bg-hover;
                                                    button-bg-active: root.button-bg-active;
                                                    border-default: root.border-default;
                                                    accent-primary: root.accent-primary;
                                                    text-primary: root.text-primary;
                                                    text-secondary: root.text-secondary;
                                                    icon: @image-url("../../../assets/icons/RemixIcons/System/add-line.svg");
                                                    clicked => { root.command-triggered("New Layer"); }
                                                }

                                                IconButton {
                                                    bg-default: root.bg-panel-header;
                                                    button-bg-hover: root.button-bg-hover;
                                                    button-bg-active: root.button-bg-active;
                                                    border-default: root.border-default;
                                                    accent-primary: root.accent-primary;
                                                    text-primary: root.text-primary;
                                                    text-secondary: root.text-secondary;
                                                    icon: @image-url("../../../assets/icons/RemixIcons/System/delete-bin-line.svg");
                                                    clicked => { root.command-triggered("Delete Layer"); }
                                                }

                                                Rectangle {}

                                                IconButton {
                                                    bg-default: root.bg-panel-header;
                                                    button-bg-hover: root.button-bg-hover;
                                                    button-bg-active: root.button-bg-active;
                                                    border-default: root.border-default;
                                                    accent-primary: root.accent-primary;
                                                    text-primary: root.text-primary;
                                                    text-secondary: root.text-secondary;
                                                    icon: @image-url("../../../assets/icons/RemixIcons/Design/focus-2-line.svg");
                                                }
                                            }
                                        }

                                        if root.bottom-panel-index == 1 : Rectangle {
                                            background: root.bg-panel;
                                            vertical-stretch: 1;

                                            VerticalLayout {
                                                padding-top: 8px;
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                spacing: 6px;
                                                Text { text: "Channels"; color: root.text-primary; font-size: 10px; font-weight: 600; }
                                                for channel in ["RGB", "Red", "Green", "Blue"] : Rectangle {
                                                    height: 20px;
                                                    border-radius: 3px;
                                                    background: root.bg-panel-header;
                                                    border-color: root.border-default;
                                                    border-width: 1px;
                                                    Text { text: channel; color: root.text-secondary; font-size: 9px; vertical-alignment: center; x: 6px; }
                                                }
                                                Rectangle {}
                                            }
                                        }

                                        if root.bottom-panel-index == 2 : Rectangle {
                                            background: root.bg-panel;
                                            vertical-stretch: 1;

                                            VerticalLayout {
                                                padding-top: 8px;
                                                padding-left: 8px;
                                                padding-right: 8px;
                                                spacing: 6px;
                                                Text { text: "Paths"; color: root.text-primary; font-size: 10px; font-weight: 600; }
                                                Rectangle {
                                                    min-height: 42px;
                                                    border-radius: 3px;
                                                    background: root.bg-panel-header;
                                                    border-color: root.border-default;
                                                    border-width: 1px;
                                                    Text { text: "Work path"; color: root.text-secondary; font-size: 9px; vertical-alignment: center; x: 6px; }
                                                }
                                                Rectangle {}
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: root.status-bar-height;
            background: root.bg-chrome;
            border-color: root.border-subtle;
            border-width: 1px;

            HorizontalLayout {
                padding-left: root.panel-padding;
                padding-right: root.panel-padding;
                spacing: 10px;

                Text {
                    text: root.zoom-label + "  |  " + root.canvas-size-label;
                    color: root.text-secondary;
                    font-size: 11px;
                    font-weight: 500;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 1px;
                    background: root.border-subtle;
                }

                Text {
                    text: root.cursor-position-label;
                    color: root.text-muted;
                    font-size: 11px;
                    vertical-alignment: center;
                }

                Text {
                    text: root.selection-bounds-label;
                    color: root.text-muted;
                    font-size: 11px;
                    vertical-alignment: center;
                }

                Rectangle {}

                Text {
                    text: "FG " + root.foreground-color-label + "  BG " + root.background-color-label;
                    color: root.text-secondary;
                    font-size: 11px;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 1px;
                    background: root.border-subtle;
                }

                Text {
                    text: root.status-message;
                    color: root.text-muted;
                    font-size: 11px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }
    }
}
