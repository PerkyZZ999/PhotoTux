                    button-bg-active: root.button-bg-active;
                    label: root.tool-option-tertiary-label;
                    value: root.tool-opacity-label;
                    decrement => { root.tool-option-adjusted("opacity", -1); }
                    increment => { root.tool-option-adjusted("opacity", 1); }
                }

